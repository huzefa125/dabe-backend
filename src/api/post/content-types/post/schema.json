{
  "kind": "collectionType",
  "collectionName": "posts",
  "info": {
    "singularName": "post",
    "pluralName": "posts",
    "displayName": "Post",
    "description": "News and blog posts"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "excerpt": {
      "type": "text"
    },
    "category": {
      "type": "string"
    },
    "readTime": {
      "type": "string"
    },
    "publishedAtDate": {
      "type": "date"
    },
    "coverImageUrl": {
      "type": "string"
    },
    "content": {
      "type": "text"
    }
  }
}
